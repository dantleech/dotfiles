-R
--exclude=.git
--exclude=**/cache/**
--exclude=vendor/**/vendor/**
--tag-relative=yes
--languages=php
--PHP-kinds=+cfi-v
--regex-PHP=/abstract\s+class\s+([^ ]+)/\1/c/
--regex-PHP=/interface\s+([^ ]+)/\1/c/
--regex-PHP=/(public\s+|static\s+|abstract\s+|protected\s+|private\s+)function\s+\&?\s*([^ (]+)/\2/f/
